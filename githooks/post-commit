#!/bin/sh
# Auto-push the current branch to origin after every successful commit.
# Disable for one commit: SKIP_AUTO_PUSH=1 git commit ...
# Disable permanently: git config --unset core.hooksPath

if [ -n "$SKIP_AUTO_PUSH" ]; then
  exit 0
fi

branch=$(git symbolic-ref --short HEAD 2>/dev/null) || exit 0

echo "post-commit: pushing $branch to origin..."
git push origin "$branch" || {
  echo "post-commit: git push failed (fix remote/auth and run: git push)"
  exit 1
}
